POSTGRES_USER=swiftsnipple
POSTGRES_PASSWORD=swiftsnipple
POSTGRES_DB=swiftsnipple
POSTGRES_PORT=5432

API_PORT=8080
WEB_PORT=3000
ADMIN_EMAIL=creator@justdoswift.com
ADMIN_PASSWORD=secret12
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
UPLOADS_DIR=uploads

# Used by the Go API outside Docker. In Docker Compose, the API service will derive
# a service-to-service DATABASE_URL automatically.
DATABASE_URL=postgres://swiftsnipple:swiftsnipple@localhost:5432/swiftsnipple?sslmode=disable

# Used when building the API image. For mainland China or Tencent Cloud, consider:
# GOPROXY=https://goproxy.cn,direct
# If the checksum service is also unreachable, set:
# GOSUMDB=off
GOPROXY=https://proxy.golang.org,direct
GOSUMDB=sum.golang.org

# Used by the Vite dev server proxy when the web app runs in Docker Compose.
VITE_API_PROXY_TARGET=http://api:8080

# Production / reverse proxy settings
CADDY_DOMAIN=localhost
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
