# Local app ports
POSTGRES_PORT=5432
API_PORT=8080
WEB_PORT=3000

# Local PostgreSQL bootstrap
POSTGRES_USER=swiftsnipple
POSTGRES_PASSWORD=swiftsnipple
POSTGRES_DB=swiftsnipple
DATABASE_URL=postgres://swiftsnipple:swiftsnipple@localhost:5432/swiftsnipple?sslmode=disable

# Admin and member auth
ADMIN_EMAIL=creator@justdoswift.com
ADMIN_PASSWORD=secret12
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
MEMBER_SESSION_SECRET=replace-with-another-long-random-string

# Billing
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_SUCCESS_URL=http://localhost:3000/account?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/account?checkout=cancelled
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/account

# Asset storage
STORAGE_PROVIDER=minio
UPLOADS_DIR=uploads
UPLOADS_BASE_PATH=/api/uploads

# MinIO storage settings
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=swiftsnipple
MINIO_SECRET_KEY=replace-with-a-long-minio-secret
MINIO_BUCKET=swiftsnipple-assets
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_ROOT_USER=swiftsnipple
MINIO_ROOT_PASSWORD=replace-with-a-long-minio-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# GCS storage settings (used when STORAGE_PROVIDER=gcs)
GCS_BUCKET=
GCS_PROJECT_ID=
GCS_CREDENTIALS=
GCS_PUBLIC_BASE_URL=

# Frontend dev server -> API proxy target
VITE_API_PROXY_TARGET=http://api:8080
