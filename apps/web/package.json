{
  "name": "@swiftsnippet/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "PID_FILE=../../.swiftsnippet.e2e.pids bash ../../scripts/stop.sh >/dev/null 2>&1 || true && (lsof -tiTCP:13001 -sTCP:LISTEN | xargs kill >/dev/null 2>&1 || true) && (lsof -tiTCP:18081 -sTCP:LISTEN | xargs kill >/dev/null 2>&1 || true) && playwright test"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@playwright/test": "latest",
    "@sveltejs/adapter-auto": "latest",
    "@sveltejs/kit": "^2.17.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/svelte": "^5.3.1",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "csstype": "^3.2.3",
    "jsdom": "^26.1.0",
    "svelte": "^5.28.2",
    "svelte-check": "^4.1.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@fontsource/fustat": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/inter": "^5.2.8"
  }
}
